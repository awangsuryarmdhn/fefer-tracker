# ALL optional. Defaults live in main.ts (FEFER chain 988).
# Local:  cp .env.example .env  →  deno task start:env
# Deploy: leave empty, OR set keys one-by-one in dashboard (never paste blank lines).
# Docs:   https://docs.deno.com/deploy/classic/environment-variables/

# --- RPC engine (server-side only; client never hits chain) ---
# Single: RPC_URL=https://rpc.stable.xyz
# Multi failover/rotate (comma-separated) — Twitter "RPC engine" pattern:
# RPC_URLS=https://rpc.stable.xyz,https://backup.example/rpc
RPC_URL=https://rpc.stable.xyz
# RPC_URLS=
RPC_TIMEOUT_MS=8000
PRICE_CACHE_MS=3500
HOLD_CACHE_MS=3000
# Shared price cache via Deno KV (Deploy multi-isolate). 1 key only, not per-wallet.
# Deploy: assign Deno KV to app → openKv() auto. Local: openKv() uses local DB.
# Hold stays in-mem — per-wallet KV = ops waste. USE_KV=0 → mem-only.
USE_KV=1

# --- chain / contracts (optional overrides) ---
CHAIN_ID=988
PAIR=0x3dea4be5615974f31624404ef288ba3b36dfeb83
TOKEN=0xeaf7aC0FdF150CDD89340fB762D83848De6A7b83
TOKEN_SYMBOL=FEFER
TOKEN_DECIMALS=18
QUOTE_TOKEN=0x817997ca8394e26cce3de3a076a4889b27dbf9de
QUOTE_SYMBOL=WgUSDT
QUOTE_DECIMALS=18

# --- UI defaults / links (optional) ---
DEFAULT_WALLET=0x1E1afF9d9E387D69b89839E477e63f24e5Ec12C5
EXPLORER_BASE=https://stablescan.xyz
BRIDGE_URL=https://stargate.finance/?srcChain=plasma&srcToken=0xB8CE59FC3717ada4C02eaDF9682A9e934F625ebb&dstChain=stable&dstToken=0x779Ded0c9e1022225f8E0630b35a9b54bE713736
DYOR_URL=https://dyorswap.org/launchinfo/?id=0xeaf7aC0FdF150CDD89340fB762D83848De6A7b83&chainId=988
# BasedBot Telegram — Buy/Sell CTA (same deep-link for both)
TRADE_BOT_URL=https://t.me/based_eth_bot?start=r_Leviathanzx_b_0xeaf7ac0fdf150cdd89340fb762d83848de6a7b83

# --- local only ---
# PORT: Deno.serve listen port (default 8000).
# Do NOT set on Deno Deploy — platform binds HTTP.
# Deploy presets (auto, do not set): DENO_REGION, DENO_DEPLOYMENT_ID
PORT=8000

# --- PWA / client notes ---
# Client thin: /api/snapshot only + BasedBot iframe (lazy).
# SW caches shell; /api/* always network. Icons SVG (add PNG for old iOS if need).